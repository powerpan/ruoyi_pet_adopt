# Copy this file to deploy/.env before starting the Docker package.

# Web ports on the host machine.
BACKEND_PORT=8080
ADMIN_PORT=8081
PET_APP_PORT=8088

# Optional local ports for database debugging. The application uses Docker
# internal networking, so these can be changed or removed if they conflict.
MYSQL_PORT=3307
REDIS_PORT=6380

# Database and Redis settings used inside Docker.
MYSQL_DATABASE=ruoyi_pet_adopt
MYSQL_ROOT_PASSWORD=ruoyi_pet_adopt_root
REDIS_DATABASE=0
REDIS_PASSWORD=

# Set your own admin password before the first startup.
RUOYI_PET_ADOPT_BOOTSTRAP_ADMIN_PASSWORD=admin123

# Change this for shared deployments.
RUOYI_PET_ADOPT_TOKEN_SECRET=ruoyi-pet-adopt-docker-local-token-secret
